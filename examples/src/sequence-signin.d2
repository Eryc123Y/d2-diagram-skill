# DIAGRAM TYPE: Sequence
# AUDIENCE: Application and platform engineers
# Shows: A production checkout orchestration with fraud, inventory, payment, and notification steps

Checkout flow: {
  shape: sequence_diagram

  user: Customer
  app: Web App
  api: Checkout API
  fraud: Fraud service
  inventory: Inventory service
  payments: Payment gateway
  orders: Order service
  email: Notification service

  happy_path: Happy path {
    user -> app: submit checkout
    app -> api: create checkout session
    api -> fraud: evaluate basket
    fraud -> api: risk score = low
    api -> inventory: reserve stock
    inventory -> api: reservation confirmed
    api -> payments: authorize payment
    payments -> api: authorization approved
    api -> orders: create order
    orders -> api: order placed
    api -> email: send confirmation
    email -> api: queued
    api -> app: checkout success
    app -> user: render confirmation page
  }

  payment_failure: Payment failure branch {
    app -> api: retry failed checkout
    api -> payments: authorize payment
    payments -> api: authorization declined
    api -> inventory: release reservation
    inventory -> api: reservation released
    api -> app: payment failed
    app -> user: show retry and support options
  }
}
