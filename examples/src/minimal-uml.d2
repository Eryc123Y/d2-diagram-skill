# DIAGRAM TYPE: UML Class Diagram
# AUDIENCE: Backend and domain engineers
# Shows: A production-grade commerce domain with aggregates, policies, fulfillment, and payment integration

direction: right

vars: {
  d2-config: {
    sketch: false
    theme-id: 0
    layout-engine: elk
  }
}

Customer: {
  shape: class
  +id: UUID
  +email: string
  +defaultCurrency: Currency
}

Address: {
  shape: class
  +line1: string
  +city: string
  +country: string
  +postalCode: string
}

Order: {
  shape: class
  +id: UUID
  +status: OrderStatus
  +submit(): void
  +cancel(reason: string): void
  +capturePayment(): Receipt
}

OrderLine: {
  shape: class
  +sku: string
  +quantity: int
  +unitPrice: Money
}

Shipment: {
  shape: class
  +id: UUID
  +trackingNumber: string
  +markPacked(): void
  +markDelivered(): void
}

Invoice: {
  shape: class
  +id: UUID
  +issue(): void
  +markPaid(): void
}

PaymentProvider: {
  shape: class
  +authorize(orderId: UUID, amount: Money): Authorization
  +capture(paymentId: string): Receipt
}

StripeAdapter: {
  shape: class
  -client: StripeClient
  +authorize(orderId: UUID, amount: Money): Authorization
  +capture(paymentId: string): Receipt
}

DiscountPolicy: {
  shape: class
  +apply(order: Order): Money
}

CampaignDiscount: {
  shape: class
  +campaignId: UUID
  +apply(order: Order): Money
}

FulfillmentPlanner: {
  shape: class
  +reserve(order: Order): Reservation
  +createShipment(order: Order): Shipment
}

DomainEventPublisher: {
  shape: class
  +publish(event: DomainEvent): void
}

Order -> OrderLine: contains {
  source-arrowhead.shape: diamond
  source-arrowhead.style.filled: true
}

Order -> Shipment: creates {
  source-arrowhead.shape: diamond
  source-arrowhead.style.filled: true
}

Order -> Invoice: produces {
  source-arrowhead.shape: diamond
  source-arrowhead.style.filled: true
}

Customer -> Address: stores {
  source-arrowhead.shape: diamond
  source-arrowhead.style.filled: false
}

Order -> Customer: placed by
Order -> DiscountPolicy: evaluated by {
  style.stroke-dash: 5
}
Order -> FulfillmentPlanner: planned by {
  style.stroke-dash: 5
}
Order -> DomainEventPublisher: emits events {
  style.stroke-dash: 5
}

CampaignDiscount -> DiscountPolicy: specializes {
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: false
}

StripeAdapter -> PaymentProvider: realizes {
  style.stroke-dash: 5
  target-arrowhead.shape: triangle
  target-arrowhead.style.filled: false
}

Order -> PaymentProvider: charges through {
  style.stroke-dash: 5
}
