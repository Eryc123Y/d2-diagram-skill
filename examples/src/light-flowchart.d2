# DIAGRAM TYPE: Flowchart
# AUDIENCE: Delivery managers and platform teams
# Shows: A production release governance flow with quality, security, canary, and rollback gates

direction: down

vars: {
  d2-config: {
    sketch: true
    theme-id: 0
    layout-engine: elk
  }
}

start: Merge to main {
  shape: oval
}

build: Build artifacts {
  shape: step
}

unit: Run unit and contract tests {
  shape: step
}

security: Run SAST, secrets, and dependency scan {
  shape: step
}

quality_gate: Quality gate passed? {
  shape: diamond
}

fixes: Reject release and open remediation ticket {
  shape: callout
}

staging: Deploy to staging {
  shape: step
}

e2e: Run integration, E2E, and synthetic checks {
  shape: step
}

approval: Change approval granted? {
  shape: diamond
}

canary: Roll out 5 percent canary {
  shape: step
}

observe: Observe metrics, logs, and error budget {
  shape: step
}

healthy: Canary healthy? {
  shape: diamond
}

rollback: Automatic rollback and incident notification {
  shape: callout
}

progressive: Expand to 25 percent, 50 percent, 100 percent {
  shape: step
}

closeout: Publish release notes and close deployment window {
  shape: oval
}

start -> build
build -> unit
unit -> security
security -> quality_gate
quality_gate -> fixes: no
fixes -> start: new patch
quality_gate -> staging: yes
staging -> e2e
e2e -> approval
approval -> fixes: no
approval -> canary: yes
canary -> observe
observe -> healthy
healthy -> rollback: no
rollback -> start: stabilize and retry
healthy -> progressive: yes
progressive -> closeout
